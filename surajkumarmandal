<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>My Website</title>
  <style>
    body {
      margin: 0;
      font-family: sans-serif;
      line-height: 1.6;
    }

    header {
      background-color: #333;
      color: white;
      padding: 1rem;
      text-align: center;
    }

    nav a {
      color: white;
      margin: 0 15px;
      text-decoration: none;
    }

    section {
      padding: 2rem;
    }

    .container {
      max-width: 1000px;
      margin: auto;
      padding: 1rem;
    }

    footer {
      background-color: #333;
      color: white;
      text-align: center;
      padding: 1rem;
    }

    @media (max-width: 600px) {
      nav a {
        display: block;
        margin: 10px 0;
      }
    }
  </style>
</head>
<body>
  <header>
    <h1>Welcome to My Website</h1>
    <nav>
      <a href="#home">Home</a>
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <main class="container">
    <section id="home">
      <h2>Home</h2>
      <p>This is the home section of your simple personal or business website.</p>
    </section>

    <section id="about">
      <h2>About</h2>
      <p>Here you can describe yourself or your business in a few sentences.</p>
    </section>

    <section id="services">
      <h2>Services</h2>
      <p>List your services or products you offer.</p>
    </section>

    <section id="contact">
      <h2>Contact</h2>
      <p>Email: your@email.com</p>
      <p>Phone: +977-98XXXXXXXX</p>
    </section>
  </main>

  <footer>
    <p>© 2025 Your Name. All rights reserved.</p>
  </footer>
</body>
</html>
